{
  "name": "signalk-ajrm-marine-capture",
  "version": "0.5.20",
  "description": "Voyage capture and diagnostic bundle builder for AJRM Marine Suite testing.",
  "main": "plugin/index.js",
  "scripts": {
    "test": "node --test \"test/**/*.test.js\" && node --check plugin/index.js && node --check public/app.js"
  },
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-webapp",
    "signalk-category-utility",
    "diagnostics",
    "logger",
    "voyage",
    "signal-k",
    "signalk",
    "ajrm-marine-suite",
    "marine",
    "navigation"
  ],
  "author": "Anthony McDonald, with assistance from William McAusland",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ajrm-marine-suite/signalk-ajrm-marine-capture.git"
  },
  "bugs": {
    "url": "https://github.com/ajrm-marine-suite/signalk-ajrm-marine-capture/issues"
  },
  "homepage": "https://github.com/ajrm-marine-suite/signalk-ajrm-marine-capture#readme",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "plugin",
    "public",
    "README.md",
    "LICENSE"
  ],
  "signalk-plugin-enabled-by-default": true,
  "signalk": {
    "displayName": "AJRM Marine Capture",
    "appIcon": "./icon.svg",
    "recommends": [
      "signalk-ajrm-marine-logger",
      "signalk-ajrm-marine-snapshot",
      "signalk-ajrm-marine-voyage-viewer"
    ]
  },
  "dependencies": {
    "adm-zip": "^0.5.18"
  }
}
